[workflow]
name = "scatter-test"
version = "1.0.0"

[config]
chromosomes = ["chr1", "chr2", "chr3"]

[defaults]
threads = 2

[[rules]]
name = "create_bam"
output = ["data/sample.bam"]
shell = "mkdir -p data && touch data/sample.bam"

[[rules]]
name = "call_variants"
input = ["data/sample.bam"]
output = ["variants/sample.{chr}.vcf"]
scatter = { variable = "chr", values_from = "config.chromosomes", gather = "merge_vcfs" }
shell = "echo 'Calling {chr}' > variants/sample.{chr}.vcf"

[[rules]]
name = "merge_vcfs"
output = ["variants/merged.vcf"]
shell = "echo 'Merged' > {output[0]}"
