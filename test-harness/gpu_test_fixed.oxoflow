[workflow]
name = "gpu-test-fixed"
version = "1.0.0"

[defaults]
threads = 2
memory = "8G"

[[rules]]
name = "gpu_task"
output = ["gpu_output.txt"]
shell = """
echo "Running on GPU" > gpu_output.txt
echo "Threads: {threads}" >> gpu_output.txt
echo "Memory: {memory}" >> gpu_output.txt
nvidia-smi >> gpu_output.txt
"""

[rules.resources]
threads = 4
memory = "16G"
gpu = 1

[rules.environment]
modules = ["cuda"]
