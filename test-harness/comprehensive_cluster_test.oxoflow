[workflow]
name = "comprehensive-cluster-test"
version = "1.0.0"
description = "Comprehensive cluster execution test with all resource types"
author = "oxo-flow-test"

[defaults]
threads = 2
memory = "4G"
time = "1h"

# Test: Environment groups
[env_groups.qc]
modules = ["fastqc/0.11.9"]

[env_groups.align]
modules = ["bwa/0.7.17", "samtools/1.16"]

# Test: Basic setup
[[rules]]
name = "setup_environment"
output = ["data/samples.txt"]
shell = "mkdir -p data && echo 'sample1 sample2 sample3' > data/samples.txt"

# Test: QC with env_group
[[rules]]
name = "run_qc"
input = ["data/samples.txt"]
output = ["qc/report.html"]
threads = 2
memory = "4G"
env_group = "qc"
shell = """
mkdir -p qc
echo "QC Report" > qc/report.html
echo "Threads: {threads}, Memory: {memory}" >> qc/report.html
module list >> qc/report.html 2>&1 || true
"""

# Test: Alignment with high resources
[[rules]]
name = "run_alignment"
input = ["data/samples.txt"]
output = ["aligned/result.bam"]
threads = 8
memory = "16G"
env_group = "align"
shell = """
mkdir -p aligned
echo "Alignment complete" > aligned/result.bam
echo "Threads: {threads}, Memory: {memory}" >> aligned/result.bam
hostname >> aligned/result.bam
date >> aligned/result.bam
"""

# Test: GPU variant calling with full spec
[[rules]]
name = "gpu_variant_calling"
input = ["aligned/result.bam"]
output = ["variants/output.vcf"]
threads = 4
resources = { gpu = 1, memory = "32G" }
environment = { modules = ["cuda/12.0", "gatk/4.4"] }
shell = """
mkdir -p variants
echo "GPU Variant Calling" > variants/output.vcf
echo "Threads: {threads}, Memory: {memory}" >> variants/output.vcf
nvidia-smi >> variants/output.vcf 2>&1 || echo "GPU not available" >> variants/output.vcf
"""

# Test: Multi-GPU deep learning
[[rules]]
name = "deep_learning"
input = ["variants/output.vcf"]
output = ["models/model.pt"]
threads = 16
resources = { gpu = 4, memory = "64G" }
environment = { modules = ["cuda/12.0", "pytorch/2.0"] }
shell = """
mkdir -p models
echo "Deep Learning Model" > models/model.pt
echo "GPUs: 4, Memory: {memory}" >> models/model.pt
echo "Training complete" >> models/model.pt
"""

# Test: Final aggregation
[[rules]]
name = "generate_report"
input = ["qc/report.html", "aligned/result.bam", "variants/output.vcf", "models/model.pt"]
output = ["reports/final.html"]
threads = 1
memory = "4G"
shell = """
mkdir -p reports
echo "<html><body><h1>Final Report</h1></body></html>" > reports/final.html
"""
