[workflow]
name = "comprehensive-test"
version = "1.0.0"
description = "Comprehensive test workflow for oxo-flow validation"
author = "test-suite"

[config]
test_data = "./test-data"
output_dir = "./outputs"
chromosomes = ["chr1", "chr2", "chr3"]

[defaults]
threads = 2
memory = "4G"
time = "1h"

[[rules]]
name = "setup_data"
output = ["test-data/samples.txt", "test-data/reference.fa"]
threads = 1
shell = """
mkdir -p test-data
# Create sample list
echo "sample1" > test-data/samples.txt
echo "sample2" >> test-data/samples.txt
echo "sample3" >> test-data/samples.txt
# Create reference file
echo ">ref" > test-data/reference.fa
echo "ATCGATCGATCGATCGATCGATCG" >> test-data/reference.fa
"""

[[rules]]
name = "process_sample"
input = ["test-data/samples.txt"]
output = ["outputs/sample1_processed.txt", "outputs/sample2_processed.txt", "outputs/sample3_processed.txt"]
threads = 2
memory = "4G"
shell = """
mkdir -p outputs
for sample in sample1 sample2 sample3; do
    echo "Processing $sample on $(hostname)" > outputs/${sample}_processed.txt
    echo "Threads: {threads}" >> outputs/${sample}_processed.txt
    echo "Memory: {memory}" >> outputs/${sample}_processed.txt
    date >> outputs/${sample}_processed.txt
done
"""

[[rules]]
name = "qc_check"
input = ["outputs/sample1_processed.txt", "outputs/sample2_processed.txt", "outputs/sample3_processed.txt"]
output = ["outputs/sample1_qc.txt", "outputs/sample2_qc.txt", "outputs/sample3_qc.txt"]
threads = 1
shell = """
for sample in sample1 sample2 sample3; do
    echo "QC passed for $sample" > outputs/${sample}_qc.txt
    echo "Status: OK" >> outputs/${sample}_qc.txt
done
"""

[[rules]]
name = "aggregate"
input = ["outputs/sample1_qc.txt", "outputs/sample2_qc.txt", "outputs/sample3_qc.txt"]
output = ["outputs/final_report.txt"]
threads = 1
shell = """
echo "Final Report" > {output[0]}
echo "============" >> {output[0]}
for f in {input}; do
    echo "---" >> {output[0]}
    cat $f >> {output[0]}
done
echo "============" >> {output[0]}
echo "All samples processed successfully" >> {output[0]}
"""
