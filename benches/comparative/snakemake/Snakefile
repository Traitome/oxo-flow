"""
oxo-flow 对比基准 — Snakemake 等效管线

与 benches/macro/suite.py 中 generate_hello(N) 生成的 oxo-flow
管线等价: N 步顺序链。

用法:
    snakemake --cores 1
"""

COUNT = 10

rule all:
    input:
        f"step_{COUNT - 1}_output.txt"

rule step_0:
    output: "step_0_output.txt"
    shell: "echo 0 > {output}"

rule step_i:
    input:
        f"step_{{wildcards.i - 1}}_output.txt"
    output:
        "step_{i}_output.txt"
    wildcard_constraints:
        i = "[1-9][0-9]*"
    shell: "echo {wildcards.i} > {output}"
